{
  "name": "openclaw-stack",
  "version": "0.1.0",
  "description": "TypeScript OpenClaw runtime stack with unified memory and diary persistence.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
